# ─── Charly Agent — Variables de Entorno ─────────────────────────────────────────
# Copia este archivo a .env y rellena con tus credenciales reales
# NUNCA subas .env a GitHub

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-api03-...

# Apps Script Web App (GET-based, URL pública)
APPS_SCRIPT_URL=https://script.google.com/macros/s/TU_DEPLOYMENT_ID/exec

# Discord webhook del canal #finanzas (o #charly)
# Crea uno en: Discord → Canal → Configuración → Integraciones → Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/TU_WEBHOOK_ID/TU_WEBHOOK_TOKEN

# Puerto del servidor HTTP (para n8n)
PORT=8080
